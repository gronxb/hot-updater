{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "esnext"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@hot-updater/server/runtime": [
        "./packages/server/src/runtime.ts"
      ]
    },
    "rootDir": ".",
    "isolatedModules": true,
    "strict": true,
    "declaration": true,
    "noEmit": true,
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "pretty": true
  }
}
