{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "esnext"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@hot-updater/server/runtime": [
        "packages/server/src/runtime.ts"
      ]
    },
    "rootDir": ".",
    "isolatedModules": true,
    "strict": true,
    "declaration": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "pretty": true
  }
}
