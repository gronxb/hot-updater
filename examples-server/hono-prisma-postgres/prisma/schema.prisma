// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Hot Updater models

// --- BEGIN HOT-UPDATER MODELS (DO NOT EDIT) ---
model bundles {
  id String @db.Uuid @id
  platform String
  should_force_update Boolean
  enabled Boolean
  file_hash String
  git_commit_hash String?
  message String?
  channel String
  storage_uri String
  target_app_version String?
  fingerprint_hash String?
  metadata Json
  manifest_storage_uri String?
  manifest_file_hash String?
  asset_base_storage_uri String?
  patch_base_bundle_id String?
  patch_base_file_hash String?
  patch_file_hash String?
  patch_storage_uri String?
  rollout_cohort_count Int @default(1000)
  target_cohorts Json?
}
model private_hot_updater_settings {
  key String @db.VarChar(255) @id
  value String @default("0.31.0")
}
// --- END HOT-UPDATER MODELS ---
