{
  "name": "@examples-server/elysia-drizzle-libsql",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:type": "tsc --noEmit",
    "db:generate": "npx hot-updater db generate src/db.ts --yes",
    "db:push": "npx drizzle-kit push"
  },
  "dependencies": {
    "@elysiajs/node": "^1.0.3",
    "@hot-updater/aws": "workspace:*",
    "@hot-updater/core": "workspace:*",
    "@hot-updater/mock": "workspace:*",
    "@hot-updater/server": "workspace:*",
    "@libsql/client": "catalog:db",
    "dotenv": "^16.6.1",
    "drizzle-orm": "catalog:db",
    "elysia": "^1.4.17",
    "memoirist": "^0.4.0"
  },
  "devDependencies": {
    "@hot-updater/test-utils": "workspace:*",
    "@types/node": "^20.11.17",
    "drizzle-kit": "^0.31.6",
    "execa": "catalog:tools",
    "hot-updater": "workspace:*",
    "prisma": "catalog:db",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  }
}
