{
  "name": "@hot-updater/root",
  "private": true,
  "description": "React Native OTA solution for self-hosted",
  "keywords": [],
  "license": "MIT",
  "scripts": {
    "lint:fix": "oxfmt --write \"packages/**/*.{ts,tsx}\" \"plugins/**/*.{ts,tsx}\" \"docs/**/*.{ts,tsx}\" && oxlint --fix --fix-suggestions --fix-dangerously packages plugins docs",
    "lint": "oxfmt --check \"packages/**/*.{ts,tsx}\" \"plugins/**/*.{ts,tsx}\" \"docs/**/*.{ts,tsx}\" && oxlint packages plugins docs",
    "clear": "rimraf --glob **/dist .nx",
    "test": "vitest run --project=\"unit:*\"",
    "test:integration": "vitest run --project=\"integration:*\"",
    "test:swift": "swift test --package-path packages/react-native/ios/HotUpdater",
    "bench": "node ./scripts/bench.mjs",
    "bench:update-check": "node ./scripts/bench.mjs packages/server/src/db/pluginUpdateCheck.bench.ts packages/server/src/db/ormUpdateCheck.bench.ts",
    "bench:update-check:plugin": "node ./scripts/bench.mjs packages/server/src/db/pluginUpdateCheck.bench.ts",
    "bench:update-check:orm": "node ./scripts/bench.mjs packages/server/src/db/ormUpdateCheck.bench.ts",
    "bench:lambda": "node ./scripts/bench.mjs plugins/aws/lambda/updateCheck.bench.ts",
    "bench:lambda:memory": "node ./scripts/bench-memory.mjs plugins/aws/lambda/updateCheck.memory.spec.ts",
    "build": "nx run-many --target=build --projects=packages/*,plugins/*,docs",
    "fingerprint:create": "nx run-many --target='fingerprint:create' --projects=examples/*",
    "e2e:maestro": "node --experimental-strip-types ./e2e/maestro/scripts/run.ts",
    "e2e:maestro:ios": "node --experimental-strip-types ./e2e/maestro/scripts/run.ts --platform ios",
    "e2e:maestro:android": "node --experimental-strip-types ./e2e/maestro/scripts/run.ts --platform android",
    "test:type": "nx run-many --target=test:type --projects=packages/*,plugins/*,docs,examples-server/*",
    "release:test": "nx release --dry-run",
    "release": "pnpm clear && pnpm build && nx release --skip-publish",
    "publish:all": "nx release publish",
    "publish:rc": "nx release publish --tag rc",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@cloudflare/vitest-pool-workers": "0.13.0",
    "@hono/node-server": "catalog:hono",
    "@nx/js": "22.6.3",
    "@swc/helpers": "^0.5.17",
    "bun": "1.3.13",
    "deno-bin": "2.2.7",
    "execa": "catalog:tools",
    "hono": "catalog:hono",
    "nx": "22.6.3",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "rimraf": "^5.0.7",
    "tsdown": "catalog:tools",
    "typescript": "^6.0.2",
    "vitest": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@babel/runtime": "^7.26.10",
      "@fastify/middie": "^9.3.2",
      "@protobufjs/utf8": "^1.1.1",
      "@vitejs/plugin-rsc": "^0.5.6",
      "basic-ftp": "^5.2.0",
      "cookie": "^0.7.0",
      "cross-spawn": "^7.0.5",
      "esbuild": "^0.25.0",
      "fast-xml-builder": "^1.1.7",
      "find-my-way@8.2.0": "8.2.2",
      "form-data@2.5.3": "2.5.4",
      "form-data@3.0.3": "3.0.4",
      "hono": "4.12.18",
      "next": "16.2.6",
      "on-headers": "^1.1.0",
      "protobufjs": "^7.5.6",
      "webpack": "^5.94.0"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
