{
  "name": "hot-updater-console-template",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Standalone deployable Hot Updater Console template",
  "license": "MIT",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build && node copy-assets.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:type": "tsc --noEmit",
    "auth:generate": "auth generate --config src/lib/server/auth.server.ts",
    "auth:migrate": "auth migrate --config src/lib/server/auth.server.ts",
    "auth:bootstrap": "node --experimental-strip-types scripts/bootstrap-admin.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@hot-updater/bsdiff": "^0.35.1",
    "@hot-updater/cli-tools": "^0.35.1",
    "@hot-updater/core": "^0.35.1",
    "@hot-updater/plugin-core": "^0.35.1",
    "@hot-updater/server": "^0.35.1",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.166.7",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "hot-updater": "^0.35.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semver": "^7.7.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tar": "^7.5.16",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@tanstack/react-start": "^1.166.11",
    "@tanstack/router-plugin": "^1.166.9",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.0",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.1",
    "auth": "^1.6.23",
    "jsdom": "^29.0.0",
    "nitro": "3.0.260610-beta",
    "react-grab": "^0.1.28",
    "shadcn": "^4.0.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.2",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  }
}
