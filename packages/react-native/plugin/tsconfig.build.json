{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "node16",
    "types": ["node"],
    "moduleResolution": "node16",
    "skipLibCheck": true,
    "outDir": "build",
    "rootDir": "src",
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["./src/"],
  "exclude": ["./src/*.spec.ts"]
}
