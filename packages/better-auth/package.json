{
  "name": "@hot-updater/better-auth",
  "version": "0.35.6",
  "type": "module",
  "description": "Better Auth integration for the Hot Updater server kernel",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "test:type": "tsc --noEmit"
  },
  "repository": "https://github.com/gronxb/hot-updater",
  "author": "gronxb <gron1gh1@gmail.com> (https://github.com/gronxb)",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hot-updater/server": "workspace:*"
  },
  "peerDependencies": {
    "better-auth": "^1.6.23"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": true
    }
  }
}
