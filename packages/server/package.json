{
  "name": "@hot-updater/server",
  "version": "0.30.12",
  "type": "module",
  "description": "React Native OTA solution for self-hosted",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./adapters/drizzle": {
      "import": "./dist/adapters/drizzle.mjs",
      "require": "./dist/adapters/drizzle.cjs"
    },
    "./adapters/kysely": {
      "import": "./dist/adapters/kysely.mjs",
      "require": "./dist/adapters/kysely.cjs"
    },
    "./adapters/mongodb": {
      "import": "./dist/adapters/mongodb.mjs",
      "require": "./dist/adapters/mongodb.cjs"
    },
    "./adapters/prisma": {
      "import": "./dist/adapters/prisma.mjs",
      "require": "./dist/adapters/prisma.cjs"
    },
    "./node": {
      "import": "./dist/node.mjs",
      "require": "./dist/node.cjs"
    },
    "./runtime": {
      "import": "./dist/runtime.mjs",
      "require": "./dist/runtime.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "test:type": "tsc --noEmit"
  },
  "repository": "https://github.com/gronxb/hot-updater",
  "author": "gronxb <gron1gh1@gmail.com> (https://github.com/gronxb)",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hot-updater/core": "workspace:*",
    "@hot-updater/plugin-core": "workspace:*",
    "@hot-updater/js": "workspace:*",
    "fumadb": "catalog:db",
    "rou3": "0.7.9",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@electric-sql/pglite": "catalog:db",
    "@hot-updater/standalone": "workspace:*",
    "@hot-updater/test-utils": "workspace:*",
    "@types/node": "catalog:",
    "@types/semver": "^7.5.8",
    "execa": "catalog:tools",
    "kysely": "catalog:db",
    "kysely-pglite-dialect": "catalog:db",
    "msw": "^2.7.0",
    "uuidv7": "^1.0.2"
  }
}
