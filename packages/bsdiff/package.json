{
  "name": "@hot-updater/bsdiff",
  "version": "0.31.0",
  "description": "Hot Updater BSdiff library that produces BSDIFF40 patches for RN bspatch flows",
  "license": "MIT AND BSD-2-Clause AND bzip2-1.0.6",
  "type": "module",
  "main": "./dist/node.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workerd": "./dist/worker.js",
      "worker": "./dist/worker.js",
      "deno": "./dist/deno.js",
      "bun": "./dist/bun.js",
      "node": "./dist/node.js",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./deno": {
      "types": "./dist/deno.d.ts",
      "import": "./dist/deno.js",
      "default": "./dist/deno.js"
    },
    "./bun": {
      "types": "./dist/bun.d.ts",
      "import": "./dist/bun.js",
      "default": "./dist/bun.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js",
      "default": "./dist/worker.js"
    }
  },
  "files": [
    "NOTICE.md",
    "dist",
    "assets",
    "scripts/wasm-build",
    "rust/hdiff-wasm/Cargo.toml",
    "rust/hdiff-wasm/src"
  ],
  "scripts": {
    "build": "pnpm run build:wasm && tsdown",
    "build:watch": "tsdown --watch",
    "build:wasm": "node ./scripts/wasm-build/build-wasm.mjs",
    "test": "vitest run",
    "test:type": "tsc --noEmit",
    "test:watch": "vitest",
    "test:runtime:node": "vitest run tests/runtime.node.test.ts",
    "test:runtime:endpoints": "vitest run tests/runtime.endpoints.integration.spec.ts"
  },
  "keywords": [
    "hermes",
    "hbc",
    "bsdiff",
    "bspatch",
    "react-native"
  ],
  "repository": "https://github.com/gronxb/hot-updater",
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsdown": "catalog:tools",
    "typescript": "^6.0.2",
    "vitest": "catalog:",
    "wrangler": "^4.69.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
