import {
  analytics,
  type AnalyticsFeatureAvailable,
} from "@hot-updater/analytics";
import type { DatabasePlugin } from "@hot-updater/plugin-core";
import { createHotUpdater } from "@hot-updater/server";

declare const database: DatabasePlugin;
declare const policy: "error" | "warn";

const runtime = createHotUpdater({
  database,
  plugins: [analytics({ missingCapability: policy })],
});
const available: AnalyticsFeatureAvailable = runtime.features.analytics;

void available;
