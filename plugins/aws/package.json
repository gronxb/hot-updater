{
  "name": "@hot-updater/aws",
  "type": "module",
  "version": "0.29.3",
  "description": "React Native OTA solution for self-hosted",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "license": "MIT",
  "repository": "https://github.com/gronxb/hot-updater",
  "author": "gronxb <gron1gh1@gmail.com> (https://github.com/gronxb)",
  "bugs": {
    "url": "https://github.com/gronxb/hot-updater/issues"
  },
  "homepage": "https://github.com/gronxb/hot-updater#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./iac": {
      "types": "./dist/iac/index.d.cts",
      "import": "./dist/iac/index.mjs",
      "require": "./dist/iac/index.cjs"
    },
    "./lambda": {
      "require": "./dist/lambda/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "test:type": "tsc --noEmit"
  },
  "devDependencies": {
    "@hot-updater/core": "workspace:*",
    "@hot-updater/js": "workspace:*",
    "@hot-updater/mock": "workspace:*",
    "@hot-updater/test-utils": "workspace:*",
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "catalog:",
    "aws-sdk-client-mock": "^4.1.0",
    "es-toolkit": "^1.32.0",
    "execa": "catalog:tools",
    "mime": "^4.0.4"
  },
  "dependencies": {
    "@hot-updater/cli-tools": "workspace:*",
    "@aws-sdk/client-cloudfront": "3.1008.0",
    "@aws-sdk/client-iam": "3.1008.0",
    "@aws-sdk/client-lambda": "3.1008.0",
    "@aws-sdk/client-s3": "3.1008.0",
    "@aws-sdk/cloudfront-signer": "3.1005.0",
    "@aws-sdk/s3-request-presigner": "3.1008.0",
    "@aws-sdk/client-ssm": "3.1008.0",
    "@aws-sdk/client-sts": "3.1008.0",
    "@aws-sdk/credential-providers": "3.1008.0",
    "@aws-sdk/lib-storage": "3.1008.0",
    "@hot-updater/plugin-core": "workspace:*",
    "@hot-updater/server": "workspace:*",
    "hono": "catalog:hono",
    "aws-lambda": "1.0.7"
  }
}
