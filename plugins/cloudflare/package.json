{
  "name": "@hot-updater/cloudflare",
  "type": "module",
  "version": "0.30.3",
  "description": "React Native OTA solution for self-hosted",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./worker": {
      "types": "./dist/worker/index.d.cts",
      "import": "./dist/worker/index.mjs",
      "require": "./dist/worker/index.cjs",
      "default": "./dist/worker/index.mjs"
    },
    "./worker/config": "./worker/wrangler.json",
    "./worker/wrangler.json": "./worker/wrangler.json",
    "./iac": {
      "types": "./dist/iac/index.d.cts",
      "import": "./dist/iac/index.mjs",
      "require": "./dist/iac/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "repository": "https://github.com/gronxb/hot-updater",
  "author": "gronxb <gron1gh1@gmail.com> (https://github.com/gronxb)",
  "bugs": {
    "url": "https://github.com/gronxb/hot-updater/issues"
  },
  "homepage": "https://github.com/gronxb/hot-updater#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "sql",
    "src",
    "worker/dist",
    "worker/migrations",
    "worker/src",
    "worker/wrangler.json",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown && pnpm build:worker",
    "build:worker": "wrangler deploy worker/src/index.ts --dry-run --outdir ./worker/dist",
    "test:type": "tsc --noEmit",
    "dev": "wrangler dev worker/src/index.ts"
  },
  "dependencies": {
    "@hot-updater/cli-tools": "workspace:*",
    "@hot-updater/core": "workspace:*",
    "@hot-updater/js": "workspace:*",
    "@hot-updater/plugin-core": "workspace:*",
    "@hot-updater/server": "workspace:*",
    "cloudflare": "4.2.0",
    "hono": "catalog:hono",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.13.0",
    "@cloudflare/workers-types": "^4.20260312.1",
    "@hot-updater/test-utils": "workspace:*",
    "@types/node": "catalog:",
    "@types/semver": "^7.5.8",
    "dayjs": "^1.11.13",
    "execa": "catalog:tools",
    "mime": "^4.0.4",
    "pg-minify": "^1.6.5",
    "semver": "^7.6.3",
    "toml": "^3.0.0",
    "typescript": "^6.0.2",
    "vitest": "catalog:",
    "wrangler": "^4.5.0",
    "xdg-app-paths": "^8.3.0"
  }
}
