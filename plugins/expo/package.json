{
  "name": "@hot-updater/expo",
  "type": "module",
  "version": "0.28.0",
  "description": "React Native OTA solution for self-hosted",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "license": "MIT",
  "repository": "https://github.com/gronxb/hot-updater",
  "author": "gronxb <gron1gh1@gmail.com> (https://github.com/gronxb)",
  "bugs": {
    "url": "https://github.com/gronxb/hot-updater/issues"
  },
  "homepage": "https://github.com/gronxb/hot-updater#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:type": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/core": "7.26.0",
    "@babel/types": "7.26.0",
    "@hot-updater/bare": "workspace:*",
    "@hot-updater/cli-tools": "workspace:*",
    "@hot-updater/plugin-core": "workspace:*",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "execa": "catalog:tools",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./babel-plugin": {
      "import": "./dist/babel-plugin.js",
      "require": "./dist/babel-plugin.cjs"
    },
    "./package.json": "./package.json"
  }
}
