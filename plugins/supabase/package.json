{
  "name": "@hot-updater/supabase",
  "type": "module",
  "version": "0.30.5",
  "description": "React Native OTA solution for self-hosted",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./edge": {
      "import": "./dist/edge.mjs",
      "require": "./dist/edge.cjs"
    },
    "./scaffold": {
      "import": "./supabase/index.ts",
      "require": "./supabase/index.ts"
    },
    "./iac": {
      "types": "./dist/iac/index.d.cts",
      "import": "./dist/iac/index.mjs",
      "require": "./dist/iac/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "repository": "https://github.com/gronxb/hot-updater",
  "author": "gronxb <gron1gh1@gmail.com> (https://github.com/gronxb)",
  "bugs": {
    "url": "https://github.com/gronxb/hot-updater/issues"
  },
  "homepage": "https://github.com/gronxb/hot-updater#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "sql",
    "supabase",
    "!supabase/.temp",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "test:type": "tsc --noEmit",
    "make-migrations": "node --experimental-strip-types ./scripts/make-migrations.ts"
  },
  "dependencies": {
    "@hot-updater/core": "workspace:*",
    "@hot-updater/plugin-core": "workspace:*",
    "@hot-updater/cli-tools": "workspace:*",
    "@hot-updater/server": "workspace:*",
    "@supabase/supabase-js": "^2.76.1",
    "hono": "catalog:hono",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.15",
    "@hot-updater/js": "workspace:*",
    "@hot-updater/mock": "workspace:*",
    "@hot-updater/test-utils": "workspace:*",
    "camelcase-keys": "^9.1.3",
    "@hot-updater/postgres": "workspace:*",
    "dayjs": "^1.11.13",
    "es-toolkit": "^1.32.0",
    "execa": "catalog:tools",
    "@types/node": "catalog:",
    "mime": "^4.0.4"
  }
}
